{
  "$schema": "p18/v1/formula_similarity",
  "version": "1.0.0",
  "engine": {
    "primary_method": "Graph Neural Network embedding + cosine similarity",
    "secondary_method": "ECFP4 Tanimoto similarity on weighted ingredient fingerprints",
    "embedding_dim": 256,
    "distance_metric": "cosine",
    "index_type": "FAISS IVF-PQ (inverted file with product quantization)",
    "index_size": "145,000 formulas across all tenants (privacy-preserving per-tenant index)"
  },
  "similarity_dimensions": [
    {
      "dimension": "compositional_similarity",
      "weight": 0.40,
      "description": "Ingredient overlap and concentration similarity",
      "method": "Weighted Jaccard index on ingredient sets with concentration-adjusted scores"
    },
    {
      "dimension": "olfactory_similarity",
      "weight": 0.30,
      "description": "Predicted sensory profile similarity based on GC-MS olfactory space projection",
      "method": "Cosine similarity in 192-dim sensory embedding space (trained on 4,900 materials)"
    },
    {
      "dimension": "structural_similarity",
      "weight": 0.20,
      "description": "Molecular structure similarity of ingredient sets",
      "method": "Mean pairwise ECFP4 Tanimoto similarity between all ingredient pairs"
    },
    {
      "dimension": "commercial_similarity",
      "weight": 0.10,
      "description": "Similarity in cost structure, target market, and price positioning",
      "method": "Euclidean distance in normalized 12-dim commercial feature space"
    }
  ],
